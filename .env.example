POSTGRES_DB=nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_dev_password
POSTGRES_PORT=5433

DATABASE_URL=postgresql+psycopg://nexus:nexus_dev_password@localhost:5433/nexus

# Web client (development). dev-login is disabled unless NEXUS_DEV_LOGIN=true.
NEXUS_DEV_LOGIN=true
NEXUS_DEV_LOGIN_ORG_SLUG=acme
# Comma-separated origins allowed to call the API cross-origin (the web client).
NEXUS_CORS_ORIGINS=http://localhost:5173

# Public base URLs. The CLI verification link is built from NEXUS_WEB_BASE_URL.
NEXUS_PUBLIC_BASE_URL=http://localhost:8000
NEXUS_WEB_BASE_URL=http://localhost:5173

# Google OIDC production web login. Leave the client id/secret empty to disable OIDC
# (authorize returns 404). The client secret is SERVER-ONLY and must never ship to the
# CLI or the web client. In production, source it from a secret manager, not this file.
NEXUS_OIDC_CLIENT_ID=
NEXUS_OIDC_CLIENT_SECRET=
NEXUS_OIDC_ORG_SLUG=acme
# Comma-separated allowlist of web-client callback URLs the OIDC flow may redirect to.
NEXUS_WEB_LOGIN_REDIRECT_URIS=http://localhost:5173/auth/callback
# 32+ char signing secret for access tokens, refresh/login-code hashes, and OIDC state.
# In production, store secrets in SSM Parameter Store and point to them by value:
# any variable set to `ssm:<parameter-name>` is resolved (and decrypted) at runtime,
# e.g. NEXUS_TOKEN_SECRET=ssm:/nexus/prod/token-secret (see standards/deployment.md).
NEXUS_TOKEN_SECRET=dev-only-nexus-token-secret-change-me
