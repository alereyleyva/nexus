POSTGRES_DB=nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_dev_password
POSTGRES_PORT=5433

DATABASE_URL=postgresql+psycopg://nexus:nexus_dev_password@localhost:5433/nexus

# Web client (development). dev-login is disabled unless NEXUS_DEV_LOGIN=true.
NEXUS_DEV_LOGIN=true
NEXUS_DEV_LOGIN_ORG_SLUG=aircury
# Comma-separated origins allowed to call the API cross-origin (the web client).
NEXUS_CORS_ORIGINS=http://localhost:5173
